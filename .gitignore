*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
.venv/
venv/
ENV/
env/
.env

# uv
.uv/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# Database (允许上传数据)
# *.db
# *.sqlite
# *.sqlite3
# backend/instance/

# Uploads (允许上传简历)
# backend/uploads/*.pdf
# backend/uploads/*.docx
# backend/uploads/*.txt

# Logs
*.log
logs/

# OS
.DS_Store
Thumbs.db
Desktop.ini

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Build outputs
frontend/dist/

# Environment variables
.env
.env.local
.env.*.local
backend/.env

# Temporary files
*.tmp
*.temp
*.bak

# Test coverage
htmlcov/
.tox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.pytest_cache/

# Jupyter
.ipynb_checkpoints/

# PyTorch models (large files)
*.pt
*.pth
*.onnx

# Sentence-Transformers cache
.cache/

# poppler (if downloaded locally)
poppler/
poppler.zip
.vite/

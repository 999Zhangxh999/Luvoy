# Luvoy 环境变量配置模板
# 复制此文件为 .env 并填入实际值

# ========== LLM 配置 (必填) ==========
# API 密钥
LLM_API_KEY=sk-your-api-key-here

# API 基础 URL (默认使用通义千问)
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 模型名称
LLM_MODEL=qwen-plus

# ========== 其他可选配置 ==========
# Docker Hub 用户名 (用于镜像标签)
DOCKER_USER=maile123
